{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URPG Battle Presentation Profile",
  "type": "object",
  "required": ["id", "battleback1", "hud", "cue_timeline"],
  "properties": {
    "id": { "type": "string" },
    "battleback1": { "type": "string" },
    "battleback2": { "type": "string" },
    "media_layers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "asset"],
        "properties": {
          "id": { "type": "string" },
          "role": { "enum": ["background", "foreground", "overlay"] },
          "asset": { "type": "string" },
          "loop": { "type": "boolean" },
          "playback_rate": { "type": "number", "exclusiveMinimum": 0 },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "region_id": { "type": "integer", "minimum": 0 },
          "fade_in_frames": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "light_cues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "target", "radius", "color", "opacity"],
        "properties": {
          "id": { "type": "string" },
          "target": { "type": "string" },
          "radius": { "type": "integer", "minimum": 1 },
          "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
          "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
          "pulsate": { "type": "boolean" },
          "flicker": { "type": "boolean" },
          "hide_on_death": { "type": "boolean" }
        }
      }
    },
    "hud": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "x", "y"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["gauge", "state_icon", "turn_order", "damage_popup", "guard_marker"]
          },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "visible": { "type": "boolean" }
        }
      }
    },
    "cue_timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "frame"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "enum": ["cast", "hit", "miss", "critical", "death", "phase_transition", "victory", "defeat", "bgm", "me", "camera_shake"]
          },
          "frame": { "type": "integer", "minimum": 0 },
          "payload": { "type": "string" }
        }
      }
    }
  }
}
