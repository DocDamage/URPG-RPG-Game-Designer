{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://urpg.dev/schemas/save_migrations.schema.json",
  "title": "URPG Save Migrations Schema",
  "description": "Versioned migration contract for native save metadata and payload upgrades.",
  "type": "object",
  "required": [
    "_urpg_format_version",
    "migrations"
  ],
  "properties": {
    "_urpg_format_version": {
      "type": "string"
    },
    "migrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "ops"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "recovery_hint": {
            "type": "string"
          },
          "ops": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "op"
              ],
              "properties": {
                "op": {
                  "type": "string"
                },
                "fromPath": {
                  "type": "string"
                },
                "toPath": {
                  "type": "string"
                },
                "value": {}
              }
            }
          }
        }
      }
    }
  }
}
