{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sprite Atlas Metadata",
  "description": "Definition for a packed sprite atlas and its individual sprite rectangles.",
  "type": "object",
  "properties": {
    "atlasName": { "type": "string" },
    "texturePath": { "type": "string" },
    "size": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 2
    },
    "sprites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "w": { "type": "integer" },
          "h": { "type": "integer" },
          "pivot": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "required": ["id", "x", "y", "w", "h"]
      }
    },
    "animations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "frames": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "frameDuration": { "type": "number", "exclusiveMinimum": 0 },
          "loop": { "type": "boolean" }
        },
        "required": ["id", "frames", "frameDuration", "loop"]
      }
    },
    "preview": {
      "type": "object",
      "properties": {
        "defaultAnimation": { "type": "string" },
        "frameCount": { "type": "integer", "minimum": 0 },
        "orderedSpriteIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["defaultAnimation", "frameCount", "orderedSpriteIds"]
    }
  },
  "required": ["atlasName", "texturePath", "size", "sprites", "animations", "preview"]
}
