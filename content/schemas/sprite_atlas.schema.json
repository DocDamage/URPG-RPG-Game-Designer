{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sprite Atlas Metadata",
  "description": "Definition for a packed sprite atlas and its individual sprite rectangles.",
  "type": "object",
  "properties": {
    "atlasName": { "type": "string" },
    "texturePath": { "type": "string" },
    "size": {
      "type": "array",
      "items": { "type": "integer" },
      "minItems": 2,
      "maxItems": 2
    },
    "sprites": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "w": { "type": "integer" },
          "h": { "type": "integer" },
          "pivot": {
            "type": "array",
            "items": { "type": "integer" },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "required": ["id", "x", "y", "w", "h"]
      }
    }
  },
  "required": ["atlasName", "texturePath", "size", "sprites"]
}
