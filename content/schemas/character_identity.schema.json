{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://urpg.dev/schemas/character_identity.schema.json",
  "title": "URPG Character Identity Schema",
  "description": "Native contract for character identity serialization.",
  "type": "object",
  "required": ["schemaVersion", "name", "classId"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "classId": {
      "type": "string"
    },
    "speciesId": {
      "type": "string"
    },
    "originId": {
      "type": "string"
    },
    "backgroundId": {
      "type": "string"
    },
    "portraitId": {
      "type": "string"
    },
    "bodySpriteId": {
      "type": "string"
    },
    "portraitAssetId": {
      "type": "string"
    },
    "fieldSpriteAssetId": {
      "type": "string"
    },
    "battleSpriteAssetId": {
      "type": "string"
    },
    "baseAttributes": {
      "type": "object",
      "additionalProperties": {
        "type": "number"
      }
    },
    "appearanceTokens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layeredPartAssetIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
