{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URPG Menu Scene Graph",
  "description": "Native scene graph structure for URPG UI/Menu systems, supporting hierarchical panes and routed commands.",
  "type": "object",
  "required": ["scene_id", "panes"],
  "properties": {
    "scene_id": {
      "type": "string",
      "description": "Unique identifier for the menu scene."
    },
    "panes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/menu_pane"
      }
    }
  },
  "definitions": {
    "menu_pane": {
      "type": "object",
      "required": ["id", "commands"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "rect": {
          "type": "object",
          "properties": {
            "x": { "type": "integer" },
            "y": { "type": "integer" },
            "w": { "type": "integer" },
            "h": { "type": "integer" }
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/menu_command"
          }
        }
      }
    },
    "menu_command": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "icon_id": {
          "type": "string"
        },
        "route": {
          "type": "string",
          "enum": ["None", "Item", "Skill", "Equip", "Status", "Formation", "Options", "Save", "Load", "GameEnd", "Codex", "QuestLog", "Encyclopedia", "Custom"],
          "default": "None"
        },
        "custom_route_id": {
          "type": "string"
        },
        "fallback_route": {
          "type": "string",
          "enum": ["None", "Item", "Skill", "Equip", "Status", "Formation", "Options", "Save", "Load", "GameEnd", "Codex", "QuestLog", "Encyclopedia", "Custom"],
          "default": "None"
        },
        "fallback_custom_route_id": {
          "type": "string"
        },
        "priority": {
          "type": "integer",
          "default": 0
        },
        "visibility_rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/menu_command_condition"
          }
        },
        "enable_rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/menu_command_condition"
          }
        }
      }
    },
    "menu_command_condition": {
      "type": "object",
      "properties": {
        "switch_id": { "type": "string" },
        "variable_id": { "type": "string" },
        "variable_threshold": { "type": "integer", "default": 0 },
        "invert": { "type": "boolean", "default": false }
      }
    }
  }
}
