{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pattern Field",
  "description": "Represents a 2D coordinate pattern for skills, items, or placement masks.",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        },
        "required": ["x", "y"],
        "additionalProperties": false
      },
      "description": "Authored points must include the origin (0,0) for native pattern preview and validation workflows."
    }
  },
  "required": ["name", "points"],
  "additionalProperties": false
}
