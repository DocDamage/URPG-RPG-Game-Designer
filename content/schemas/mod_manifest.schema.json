{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mod Manifest",
  "description": "Schema for URPG mod manifest files",
  "type": "object",
  "required": ["id", "name", "version"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the mod"
    },
    "name": {
      "type": "string",
      "description": "Human-readable name of the mod"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the mod"
    },
    "author": {
      "type": "string",
      "description": "Name or identifier of the mod author"
    },
    "dependencies": {
      "type": "array",
      "description": "List of mod IDs this mod depends on",
      "items": {
        "type": "string"
      }
    },
    "entryPoint": {
      "type": "string",
      "description": "Script path or plugin name used to load the mod"
    }
  },
  "additionalProperties": false
}
