{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urpg.local/schemas/creator_package_manifest.schema.json",
  "title": "URPG Creator Package Manifest",
  "type": "object",
  "required": ["id", "type", "license_evidence", "compatibility_target", "dependencies", "validation_summary"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "minLength": 1 },
    "license_evidence": { "type": "string", "minLength": 1 },
    "compatibility_target": { "type": "string", "minLength": 1 },
    "dependencies": { "type": "array", "items": { "type": "string" } },
    "validation_summary": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
