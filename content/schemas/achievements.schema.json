{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://urpg.dev/schemas/achievements.schema.json",
  "title": "URPG Achievement Progress Schema",
  "description": "Schema for achievement registry save data.",
  "type": "object",
  "required": [
    "version",
    "progress"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "progress": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "current",
          "target",
          "unlocked"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "current": {
            "type": "integer",
            "minimum": 0
          },
          "target": {
            "type": "integer",
            "minimum": 0
          },
          "unlocked": {
            "type": "boolean"
          },
          "unlockTime": {
            "type": "string"
          }
        }
      }
    }
  }
}
