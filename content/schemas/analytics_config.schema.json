{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Analytics Configuration",
  "description": "Schema for the analytics and opt-in telemetry configuration file.",
  "type": "object",
  "required": [
    "optIn",
    "sessionId"
  ],
  "properties": {
    "optIn": {
      "type": "boolean",
      "description": "Whether the user has opted in to analytics collection."
    },
    "sessionId": {
      "type": "string",
      "description": "A unique identifier for the current analytics session."
    },
    "bufferSize": {
      "type": "integer",
      "default": 1000,
      "minimum": 1,
      "description": "Maximum number of events to retain in the buffer before dropping oldest."
    },
    "allowedCategories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of event categories that are permitted to be recorded."
    },
    "upload": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["disabled", "local_jsonl", "http_json", "custom_handler"]
        },
        "url": {
          "type": "string"
        },
        "headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "curlExecutable": {
          "type": "string"
        },
        "profileId": {
          "type": "string"
        },
        "localJsonlPath": {
          "type": "string"
        },
        "privacyReview": {
          "type": "object",
          "required": ["approved", "reviewer", "dataCategories"],
          "properties": {
            "approved": {
              "type": "boolean"
            },
            "reviewer": {
              "type": "string"
            },
            "approvedAt": {
              "type": "string"
            },
            "notes": {
              "type": "string"
            },
            "dataCategories": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
