{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urpg.dev/schemas/message_styles.schema.json",
  "title": "URPG Message Styles",
  "type": "object",
  "required": ["_urpg_format_version", "styles"],
  "properties": {
    "_urpg_format_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "styles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "namebox", "portrait"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "namebox": {
            "type": "object",
            "required": ["visible", "margin_x", "margin_y", "max_width"],
            "properties": {
              "visible": { "type": "boolean" },
              "margin_x": { "type": "integer" },
              "margin_y": { "type": "integer" },
              "max_width": { "type": "integer", "minimum": 0 }
            }
          },
          "portrait": {
            "type": "object",
            "required": ["visible", "dock", "x", "y", "width", "height"],
            "properties": {
              "visible": { "type": "boolean" },
              "dock": { "type": "string", "enum": ["left", "right"] },
              "x": { "type": "integer" },
              "y": { "type": "integer" },
              "width": { "type": "integer", "minimum": 0 },
              "height": { "type": "integer", "minimum": 0 }
            }
          },
          "window": {
            "type": "object",
            "required": ["skin", "opacity", "padding"],
            "properties": {
              "skin": { "type": "string", "description": "Asset path to the windowskin image (default: img/system/Window.png)" },
              "opacity": { "type": "integer", "minimum": 0, "maximum": 255 },
              "padding": { "type": "integer", "minimum": 0 },
              "line_height": { "type": "integer", "minimum": 1 },
              "font_size": { "type": "integer", "minimum": 1 }
            }
          },
          "audio": {
            "type": "object",
            "properties": {
              "typing_se": { "type": "string", "description": "Sound effect played during text character reveal" },
              "typing_pitch": { "type": "integer", "minimum": 50, "maximum": 150 },
              "open_se": { "type": "string" },
              "close_se": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "additionalProperties": true
}
