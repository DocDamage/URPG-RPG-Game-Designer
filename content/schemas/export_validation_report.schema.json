{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Export Validation Report",
  "type": "object",
  "required": ["target", "passed", "errors"],
  "properties": {
    "target": {
      "type": "string",
      "enum": ["Windows_x64", "Linux_x64", "macOS_Universal", "Web_WASM"]
    },
    "passed": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
