{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:urpg:loot-generator",
  "title": "URPG Loot Generator",
  "type": "object",
  "required": ["id", "base_items", "affixes"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "affixes_per_item": { "type": "integer", "minimum": 0 },
    "base_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slot", "rarity", "base_value"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "slot": { "type": "string", "minLength": 1 },
          "rarity": { "type": "string", "minLength": 1 },
          "base_value": { "type": "integer", "minimum": 0 },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "affixes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rarity", "min_value", "max_value", "economy_multiplier"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "rarity": { "type": "string", "minLength": 1 },
          "min_value": { "type": "integer" },
          "max_value": { "type": "integer" },
          "economy_multiplier": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
