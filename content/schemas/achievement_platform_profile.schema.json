{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urpg.achievement_platform_profile.v1",
  "title": "URPG Achievement Platform Profile",
  "type": "object",
  "required": ["schema", "profileId", "packageId", "backends"],
  "properties": {
    "schema": {
      "const": "urpg.achievement_platform_profile.v1"
    },
    "profileId": {
      "type": "string",
      "minLength": 1
    },
    "packageId": {
      "type": "string",
      "minLength": 1
    },
    "backends": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["platformId", "type"],
        "properties": {
          "platformId": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": ["memory", "command"]
          },
          "executable": {
            "type": "string"
          },
          "arguments": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "reviewed": {
      "type": "boolean"
    },
    "reviewedBy": {
      "type": "string"
    },
    "reviewedAt": {
      "type": "string"
    },
    "lastTestResult": {
      "type": "string",
      "enum": ["not_run", "pass", "fail"]
    }
  },
  "additionalProperties": false
}
