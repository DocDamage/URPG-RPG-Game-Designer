{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URPG Plugin Manifest",
  "description": "Definition for a URPG plugin, its dependencies, permissions, and parameters.",
  "type": "object",
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "author": { "type": "string" },
    "description": { "type": "string" },
    "dependencies": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "version": { "type": "string" },
              "optional": { "type": "boolean" }
            },
            "required": ["id"]
          }
        ]
      }
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": { "type": ["string", "number", "boolean", "object", "array"] }
    }
  },
  "required": ["id", "name", "version"]
}
