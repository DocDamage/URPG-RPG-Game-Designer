{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urpg.dev/schemas/project.schema.json",
  "title": "URPG Project",
  "type": "object",
  "required": ["_urpg_format_version", "_engine_version_min", "determinism"],
  "properties": {
    "_urpg_format_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "_engine_version_min": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "determinism": {
      "type": "object",
      "required": ["level", "authoritative_math", "physics"],
      "properties": {
        "level": { "type": "string", "enum": ["A", "B"] },
        "authoritative_math": { "type": "string", "enum": ["fixed32"] },
        "physics": {
          "type": "object",
          "required": ["authoritative"],
          "properties": {
            "authoritative": { "type": "boolean" },
            "note": { "type": "string" }
          }
        }
      }
    },
    "localization": {
      "type": "object",
      "description": "Bounded localization governance contract for repo-local bundle validation.",
      "required": ["bundleRoot", "schemaPath", "reportPath", "requiredLocales"],
      "properties": {
        "bundleRoot": {
          "type": "string",
          "minLength": 1,
          "description": "Project-relative root containing localization bundle JSON files."
        },
        "schemaPath": {
          "type": "string",
          "const": "content/schemas/localization_bundle.schema.json",
          "description": "Canonical bundle schema used by the localization consistency gate."
        },
        "reportPath": {
          "type": "string",
          "const": "imports/reports/localization/localization_consistency_report.json",
          "description": "Canonical localization consistency report consumed by ProjectAudit."
        },
        "requiredLocales": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "masterLocale": {
          "type": "string",
          "minLength": 1,
          "description": "Optional preferred master locale for completeness comparison."
        },
        "allowMissingBundles": {
          "type": "boolean",
          "description": "Whether a no-bundle report is acceptable for the current project stage."
        }
      },
      "additionalProperties": false
    },
    "input": {
      "type": "object",
      "description": "Bounded input/controller governance contract for remap and controller fixtures.",
      "required": ["bindingSchemaPath", "controllerBindingSchemaPath", "fixturePath"],
      "properties": {
        "bindingSchemaPath": {
          "type": "string",
          "const": "content/schemas/input_bindings.schema.json"
        },
        "controllerBindingSchemaPath": {
          "type": "string",
          "const": "content/schemas/controller_bindings.schema.json"
        },
        "fixturePath": {
          "type": "string",
          "const": "content/fixtures/input_bindings_fixture.json"
        },
        "controllerFixturePath": {
          "type": "string",
          "const": "content/fixtures/controller_bindings_fixture.json"
        },
        "allowUnmappedActions": {
          "type": "boolean",
          "description": "Whether authoring-time remap validation may permit unmapped actions."
        }
      },
      "additionalProperties": false
    },
    "exportProfiles": {
      "type": "array",
      "description": "Bounded export-governance profiles; this does not imply full platform signing or notarization.",
      "items": {
        "type": "object",
        "required": ["id", "target", "configSchemaPath", "validationReportSchemaPath"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "target": {
            "type": "string",
            "enum": ["Windows_x64", "Linux_x64", "macOS_Universal", "Web_WASM"]
          },
          "configSchemaPath": {
            "type": "string",
            "const": "content/schemas/export_config.schema.json"
          },
          "validationReportSchemaPath": {
            "type": "string",
            "const": "content/schemas/export_validation_report.schema.json"
          },
          "outputDir": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "startup": {
      "type": "object",
      "description": "Runtime startup scene and release map asset references.",
      "properties": {
        "map": { "type": "string", "minLength": 1 },
        "headless_safe": { "type": "boolean" },
        "map_assets": {
          "type": "object",
          "description": "Logical render asset ids and optional project-relative source paths for the startup map.",
          "properties": {
            "player_sprite": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            },
            "tileset": {
              "type": "object",
              "required": ["id"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "path": { "type": "string", "minLength": 1 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
