{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://urpg.dev/schemas/dungeon3d_world.schema.json",
  "title": "URPG 3D Dungeon World",
  "type": "object",
  "additionalProperties": false,
    "required": ["schema_version", "id", "map_id", "width", "height", "screen_width", "screen_height", "minimap_enabled", "auto_mapping", "mode", "camera", "materials", "cells"],
  "properties": {
    "schema_version": { "const": "urpg.dungeon3d_world.v1" },
    "id": { "type": "string", "minLength": 1 },
    "map_id": { "type": "string", "minLength": 1 },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "screen_width": { "type": "integer", "minimum": 1 },
    "screen_height": { "type": "integer", "minimum": 1 },
    "minimap_enabled": { "type": "boolean" },
    "auto_mapping": { "type": "boolean" },
    "mode": { "enum": ["2d", "3d", "spatial"] },
    "camera": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pos_x", "pos_y", "dir_x", "dir_y", "plane_x", "plane_y"],
      "properties": {
        "pos_x": { "type": "number" },
        "pos_y": { "type": "number" },
        "dir_x": { "type": "number" },
        "dir_y": { "type": "number" },
        "plane_x": { "type": "number" },
        "plane_y": { "type": "number" }
      }
    },
    "session": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inventory": { "type": "array", "items": { "type": "string" } },
        "discovered_cells": { "type": "array", "items": { "type": "string" } },
        "opened_doors": { "type": "array", "items": { "type": "string" } },
        "revealed_secrets": { "type": "array", "items": { "type": "string" } },
        "triggered_encounters": { "type": "array", "items": { "type": "string" } },
        "completed_markers": { "type": "array", "items": { "type": "string" } },
        "disabled_traps": { "type": "array", "items": { "type": "string" } },
        "activated_switches": { "type": "array", "items": { "type": "string" } },
        "alerted_patrols": { "type": "array", "items": { "type": "string" } },
        "activated_puzzles": { "type": "array", "items": { "type": "string" } },
        "patrol_indices": { "type": "object", "additionalProperties": { "type": "integer" } },
        "current_hiding_spot": { "type": "string" },
        "current_floor_id": { "type": "string" },
        "event_log": { "type": "array", "items": { "type": "string" } }
      }
    },
    "floors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "display_name", "depth", "ambient_sound"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "display_name": { "type": "string" },
          "depth": { "type": "integer" },
          "ambient_sound": { "type": "string" }
        }
      }
    },
    "markers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "type", "x", "y", "floor_id", "visible", "completed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "type": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "floor_id": { "type": "string" },
          "visible": { "type": "boolean" },
          "completed": { "type": "boolean" }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "text", "x", "y", "floor_id"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "floor_id": { "type": "string" }
        }
      }
    },
    "encounter_zones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "encounter_tag", "x", "y", "radius", "weight", "floor_id", "repeatable"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "encounter_tag": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "radius": { "type": "integer", "minimum": 0 },
          "weight": { "type": "integer", "minimum": 1 },
          "floor_id": { "type": "string" },
          "repeatable": { "type": "boolean" }
        }
      }
    },
    "lock_links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source_event_id", "target_door_id", "required_item", "opens_on_interact"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "source_event_id": { "type": "string", "minLength": 1 },
          "target_door_id": { "type": "string", "minLength": 1 },
          "required_item": { "type": "string" },
          "opens_on_interact": { "type": "boolean" }
        }
      }
    },
    "traps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "x", "y", "floor_id", "effect_id", "damage", "repeatable", "disarm_item", "armed"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "floor_id": { "type": "string" },
          "effect_id": { "type": "string", "minLength": 1 },
          "damage": { "type": "integer", "minimum": 0 },
          "repeatable": { "type": "boolean" },
          "disarm_item": { "type": "string" },
          "armed": { "type": "boolean" }
        }
      }
    },
    "audio_zones": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "x", "y", "radius", "floor_id", "ambient_sound", "reverb_preset"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "radius": { "type": "integer", "minimum": 0 },
          "floor_id": { "type": "string" },
          "ambient_sound": { "type": "string" },
          "reverb_preset": { "type": "string" }
        }
      }
    },
    "atmospheres": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "floor_id", "weather", "particle_preset", "light_multiplier"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "floor_id": { "type": "string" },
          "weather": { "type": "string" },
          "particle_preset": { "type": "string" },
          "light_multiplier": { "type": "number", "minimum": 0 }
        }
      }
    },
    "patrol_routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "enemy_id", "floor_id", "waypoints", "vision_range", "vision_width", "active"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "enemy_id": { "type": "string", "minLength": 1 },
          "floor_id": { "type": "string" },
          "waypoints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "integer" },
                "y": { "type": "integer" }
              }
            }
          },
          "vision_range": { "type": "integer", "minimum": 0 },
          "vision_width": { "type": "integer", "minimum": 0 },
          "active": { "type": "boolean" }
        }
      }
    },
    "hiding_spots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "x", "y", "floor_id", "required_item"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "floor_id": { "type": "string" },
          "required_item": { "type": "string" }
        }
      }
    },
    "puzzle_devices": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "label", "x", "y", "floor_id", "target_id", "required_item", "active"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 },
          "label": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "floor_id": { "type": "string" },
          "target_id": { "type": "string" },
          "required_item": { "type": "string" },
          "active": { "type": "boolean" }
        }
      }
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "wall_texture", "floor_texture", "ceiling_texture"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "wall_texture": { "type": "string", "minLength": 1 },
          "floor_texture": { "type": "string", "minLength": 1 },
        "ceiling_texture": { "type": "string", "minLength": 1 },
        "light": { "type": "number", "minimum": 0 },
        "footstep_sound": { "type": "string" }
        }
      }
    },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tile_id", "material_id", "event_id", "blocking", "dark_zone", "stairs_up", "stairs_down"],
        "properties": {
          "tile_id": { "type": "string" },
          "material_id": { "type": "string" },
          "event_id": { "type": "string" },
          "door_id": { "type": "string" },
          "required_item": { "type": "string" },
          "encounter_tag": { "type": "string" },
          "floor_transfer": { "type": "string" },
          "blocking": { "type": "boolean" },
          "dark_zone": { "type": "boolean" },
          "stairs_up": { "type": "boolean" },
          "stairs_down": { "type": "boolean" },
          "secret": { "type": "boolean" },
          "locked": { "type": "boolean" }
        }
      }
    }
  }
}
