{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "URPG Battle Troop Schema",
  "description": "Native contract for enemy groups and battle event triggers.",
  "type": "object",
  "required": ["id", "members", "phases"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["enemy_id", "x", "y"],
        "properties": {
          "enemy_id": { "type": "string" },
          "x": { "type": "integer" },
          "y": { "type": "integer" },
          "position_reuse_key": { "type": "string" },
          "hidden": { "type": "boolean", "default": false }
        }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition", "effects"],
        "properties": {
          "condition": {
            "$ref": "#/definitions/battle_condition"
          },
          "_compat_condition_fallbacks": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/compat_condition_fallback"
            }
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": { "enum": ["message", "common_event", "state_change", "force_action", "change_gold", "change_items", "change_weapons", "change_armors", "transfer_player", "game_over", "change_switches", "change_variables", "unsupported_command"] }
              }
            }
          }
        }
      }
    }
  },
  "definitions": {
    "battle_condition_leaf": {
      "type": "object",
      "properties": {
        "turn_count": { "type": "integer" },
        "hp_below_percent": { "type": "integer" },
        "switch_id": { "type": "string" },
        "enemy_index": { "type": "integer", "minimum": 0 },
        "actor_id": { "type": "string" }
      },
      "not": {
        "anyOf": [
          { "required": ["op"] },
          { "required": ["children"] }
        ]
      }
    },
    "battle_condition_group": {
      "type": "object",
      "required": ["op", "children"],
      "properties": {
        "op": { "enum": ["and", "or"] },
        "children": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/battle_condition"
          }
        }
      }
    },
    "battle_condition": {
      "oneOf": [
        { "$ref": "#/definitions/battle_condition_leaf" },
        { "$ref": "#/definitions/battle_condition_group" }
      ]
    },
    "compat_condition_fallback": {
      "type": "object",
      "required": ["type", "reason", "page_index", "source"],
      "properties": {
        "type": { "const": "unsupported_condition_tree" },
        "reason": { "type": "string" },
        "page_index": { "type": "integer", "minimum": 0 },
        "source_operator": { "type": "string" },
        "source": {}
      }
    }
  }
}
