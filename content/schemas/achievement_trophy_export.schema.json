{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://urpg.dev/schemas/achievement_trophy_export.schema.json",
  "title": "URPG Achievement Trophy Export Payload",
  "description": "Vendor-neutral achievement trophy export contract with optional platform backend submission state.",
  "type": "object",
  "required": [
    "version",
    "platform",
    "backendIntegration",
    "summary",
    "trophies"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "backendIntegration": {
      "type": "string",
      "enum": [
        "not_configured",
        "configured"
      ]
    },
    "platformBackends": {
      "type": "object"
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "unlocked",
        "secret"
      ],
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "unlocked": {
          "type": "integer",
          "minimum": 0
        },
        "secret": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "trophies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "secret",
          "unlockCondition",
          "iconId",
          "target",
          "progress",
          "unlocked"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "secret": {
            "type": "boolean"
          },
          "unlockCondition": {
            "type": "string"
          },
          "iconId": {
            "type": "string"
          },
          "target": {
            "type": "integer",
            "minimum": 0
          },
          "progress": {
            "type": "integer",
            "minimum": 0
          },
          "unlocked": {
            "type": "boolean"
          },
          "unlockTime": {
            "type": "string"
          }
        }
      }
    }
  }
}
