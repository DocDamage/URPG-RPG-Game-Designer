{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urpg/audio_pipeline_manifest",
  "title": "Audio Pipeline Manifest",
  "type": "object",
  "required": ["source_path", "outputs", "tool", "status"],
  "properties": {
    "source_path": { "type": "string" },
    "outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool": { "type": "string" },
    "status": { "type": "string" },
    "prototype_only": { "type": "boolean" }
  },
  "additionalProperties": false
}
