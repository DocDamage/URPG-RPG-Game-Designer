{
  "_urpg_format_version": "1.0",
  "_engine_version_min": "0.1.0",
  "determinism": {
    "level": "A",
    "authoritative_math": "fixed32",
    "physics": {
      "authoritative": true,
      "note": "Canonical fixture for the bounded project governance contract."
    }
  },
  "localization": {
    "bundleRoot": "content/localization",
    "schemaPath": "content/schemas/localization_bundle.schema.json",
    "reportPath": "imports/reports/localization/localization_consistency_report.json",
    "requiredLocales": ["en"],
    "masterLocale": "en",
    "allowMissingBundles": true
  },
  "input": {
    "bindingSchemaPath": "content/schemas/input_bindings.schema.json",
    "controllerBindingSchemaPath": "content/schemas/controller_bindings.schema.json",
    "fixturePath": "content/fixtures/input_bindings_fixture.json",
    "controllerFixturePath": "content/fixtures/controller_bindings_fixture.json",
    "allowUnmappedActions": false
  },
  "exportProfiles": [
    {
      "id": "windows_debug",
      "target": "Windows_x64",
      "configSchemaPath": "content/schemas/export_config.schema.json",
      "validationReportSchemaPath": "content/schemas/export_validation_report.schema.json",
      "outputDir": "build/exports/windows_debug"
    }
  ],
  "releaseAssets": {
    "manifestVersion": "1.0.0",
    "assetBundleManifestRoot": "imports/manifests/asset_bundles",
    "requiredSurfaces": ["title", "map", "battle", "ui", "audio", "icons", "fonts"],
    "assets": [
      {
        "id": "release.prototype_actor.title",
        "surface": "title",
        "category": "prototype_sprite",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-001",
        "path": "imports/normalized/prototype_sprites/gdquest_blue_actor.svg",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Bounded title/startup visual proof asset."
      },
      {
        "id": "release.prototype_actor.map",
        "surface": "map",
        "category": "prototype_sprite",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-001",
        "path": "imports/normalized/prototype_sprites/gdquest_blue_actor.svg",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Bounded map-scene player placeholder asset."
      },
      {
        "id": "release.prototype_actor.battle",
        "surface": "battle",
        "category": "prototype_sprite",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-001",
        "path": "imports/normalized/prototype_sprites/gdquest_blue_actor.svg",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Bounded battle actor/enemy placeholder asset."
      },
      {
        "id": "release.ui.silent_feedback_policy",
        "surface": "ui",
        "category": "ui_feedback_policy",
        "required": true,
        "source": "system_fallback",
        "licenseCleared": true,
        "distribution": "system_fallback",
        "notes": "Current release ships without bundled UI SFX; controls remain silent instead of depending on ignored or LFS-only WAV files."
      },
      {
        "id": "release.ui.frame_chrome",
        "surface": "ui",
        "category": "ui_frames_chrome",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-003",
        "path": "imports/normalized/release_skin/urpg_ui_frame.svg",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Repo-generated release starter UI frame/chrome asset."
      },
      {
        "id": "release.ui.cohesive_skin",
        "surface": "ui",
        "category": "cohesive_ui_skin",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-003",
        "path": "imports/normalized/release_skin/urpg_cohesive_ui_skin.json",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Repo-generated release starter skin metadata binding the governed UI/VFX assets."
      },
      {
        "id": "release.battle.vfx_flash",
        "surface": "battle",
        "category": "vfx_sheet",
        "required": true,
        "source": "asset_bundle",
        "bundleId": "BND-003",
        "path": "imports/normalized/release_skin/urpg_battle_vfx_flash.svg",
        "licenseCleared": true,
        "distribution": "bundled",
        "notes": "Repo-generated single-frame battle VFX proof asset for package coverage."
      },
      {
        "id": "release.audio.muted_fallback",
        "surface": "audio",
        "category": "audio_policy",
        "required": true,
        "source": "system_fallback",
        "licenseCleared": true,
        "distribution": "system_fallback",
        "notes": "Audio release surface is satisfied by explicit muted fallback until a non-LFS release audio asset is approved."
      },
      {
        "id": "release.icon.editor",
        "surface": "icons",
        "category": "application_icon",
        "required": true,
        "source": "repo_resource",
        "path": "resources/icons/urpg_editor.png",
        "licenseCleared": true,
        "distribution": "lfs_hydrated",
        "notes": "Editor application icon required by release package layout."
      },
      {
        "id": "release.icon.runtime",
        "surface": "icons",
        "category": "application_icon",
        "required": true,
        "source": "repo_resource",
        "path": "resources/icons/urpg_runtime.png",
        "licenseCleared": true,
        "distribution": "lfs_hydrated",
        "notes": "Runtime application icon required by release package layout."
      },
      {
        "id": "release.font.system_ui",
        "surface": "fonts",
        "category": "system_font",
        "required": true,
        "source": "system_fallback",
        "licenseCleared": true,
        "distribution": "system_fallback",
        "notes": "Current release uses platform/system text rendering; no raw vendor font pack is required."
      }
    ]
  }
}
