{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "warnings": {
        "deprecated": false
      },
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "URPG_FETCH_CATCH2": "ON",
        "URPG_USE_SCCACHE": "ON"
      }
    },
    {
      "name": "dev-vs2022",
      "displayName": "Dev (Visual Studio 2022)",
      "inherits": "base",
      "generator": "Visual Studio 17 2022"
    },
    {
      "name": "dev-mingw-debug",
      "displayName": "Dev (MinGW Debug)",
      "inherits": "base",
      "generator": "MinGW Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "URPG_USE_SCCACHE": "OFF"
      }
    },
    {
      "name": "dev-mingw-release",
      "displayName": "Dev (MinGW Release)",
      "inherits": "base",
      "generator": "MinGW Makefiles",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "URPG_USE_SCCACHE": "OFF"
      }
    },
    {
      "name": "dev-ninja-debug",
      "displayName": "Dev (Ninja Debug)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "URPG_USE_SCCACHE": "OFF"
      }
    },
    {
      "name": "dev-ninja-release",
      "displayName": "Dev (Ninja Release)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "URPG_USE_SCCACHE": "OFF"
      }
    },
    {
      "name": "release-no-tests",
      "displayName": "Release (Ninja, Tests Off)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "URPG_BUILD_TESTS": "OFF",
        "URPG_FETCH_CATCH2": "OFF"
      }
    },
    {
      "name": "ci",
      "displayName": "CI (Ninja Release + cached FetchContent)",
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_COMPILER_LAUNCHER": "sccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "sccache",
        "FETCHCONTENT_BASE_DIR": "${sourceDir}/.cache/fetchcontent",
        "URPG_SKIP_OPENGL": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev-vs2022-debug",
      "configurePreset": "dev-vs2022",
      "configuration": "Debug"
    },
    {
      "name": "dev-vs2022-release",
      "configurePreset": "dev-vs2022",
      "configuration": "Release"
    },
    {
      "name": "dev-debug",
      "configurePreset": "dev-ninja-debug"
    },
    {
      "name": "dev-release",
      "configurePreset": "dev-ninja-release"
    },
    {
      "name": "release-no-tests",
      "configurePreset": "release-no-tests"
    },
    {
      "name": "dev-mingw-debug-build",
      "configurePreset": "dev-mingw-debug"
    },
    {
      "name": "dev-mingw-release-build",
      "configurePreset": "dev-mingw-release"
    },
    {
      "name": "ci-release",
      "configurePreset": "ci"
    }
  ],
  "testPresets": [
    {
      "name": "dev-all",
      "configurePreset": "dev-ninja-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-pr",
      "configurePreset": "dev-ninja-debug",
      "filter": {
        "include": {
          "label": "^pr$"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-export",
      "configurePreset": "dev-ninja-debug",
      "filter": {
        "include": {
          "label": "^export$"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-project-audit",
      "configurePreset": "dev-ninja-debug",
      "filter": {
        "include": {
          "label": "^audit$"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-spatial",
      "configurePreset": "dev-ninja-debug",
      "filter": {
        "include": {
          "label": "^spatial$"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev-process",
      "configurePreset": "dev-ninja-debug",
      "filter": {
        "include": {
          "label": "^external$"
        }
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
